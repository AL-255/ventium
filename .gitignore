# build artifacts
/build/
obj_dir/
obj_dir_*/
*.o
*.so
*.a
*.d

# verilator / sim outputs
verif/tb/obj_dir/
verif/tb/obj_dir_sva/
verif/tb/obj_dir_selftest/
verif/soc/obj/
*.vcd
*.fst

# traces
*.vtrace
verif/**/out/

# test binaries (built from sources tracked in-tree)
verif/tests/**/*.elf
verif/tests/**/*.bin
verif/tests/**/*.flat

# M2S system-mode bare-metal test build artifacts (sources .S/.ld/manifest +
# the *.golden reference trace stay tracked; .bin/.elf/.o are rebuilt by make)
verif/sys/tests/**/*.elf
verif/sys/tests/**/*.bin
verif/sys/tests/**/*.o
# M8.4 IDE: the disk image + RTL backing-store hex are regenerated from the
# committed single source of truth gen_disk.py (the gate's Stage 0), so they are
# build artifacts, not tracked references.
verif/sys/tests/**/*.img
verif/sys/tests/**/*.disk.hex

# sphinx docs build output (sources under docs/sphinx/ are tracked)
docs/sphinx/_build/
/_site/

# fpga / Vivado synth-probe outputs (sources under fpga/{scripts,constraints}/ +
# the *.md docs are tracked; build/ holds 350+ MB of logs + .dcp checkpoints +
# per-run rpts that are regenerated by the probe tcl, so they are NOT tracked).
fpga/build/
*.dcp
# Vivado run scratch (root-dir logs/journals + the .Xil project temp dir +
# place/route artifact droppings: clockInfo.txt, cong/ congestion reports, etc.)
vivado*.log
vivado*.jou
*.backup.log
.Xil/
clockInfo.txt
/cong/
*.rpx

# python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# tooling / agent scratch
.claude/

# editor
*.swp
.DS_Store
