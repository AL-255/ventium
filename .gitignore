# build artifacts
/build/
obj_dir/
*.o
*.so
*.a
*.d

# verilator / sim outputs
verif/tb/obj_dir/
*.vcd
*.fst

# traces
*.vtrace
verif/**/out/

# test binaries (built from sources tracked in-tree)
verif/tests/**/*.elf
verif/tests/**/*.bin
verif/tests/**/*.flat

# M2S system-mode bare-metal test build artifacts (sources .S/.ld/manifest +
# the *.golden reference trace stay tracked; .bin/.elf/.o are rebuilt by make)
verif/sys/tests/**/*.elf
verif/sys/tests/**/*.bin
verif/sys/tests/**/*.o

# python
__pycache__/
*.pyc
.venv/

# editor
*.swp
.DS_Store
