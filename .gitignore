# build artifacts
/build/
obj_dir/
obj_dir_*/
*.o
*.so
*.a
*.d

# verilator / sim outputs
verif/tb/obj_dir/
verif/tb/obj_dir_sva/
verif/tb/obj_dir_selftest/
verif/soc/obj/
*.vcd
*.fst

# traces
*.vtrace
verif/**/out/

# test binaries (built from sources tracked in-tree)
verif/tests/**/*.elf
verif/tests/**/*.bin
verif/tests/**/*.flat

# M2S system-mode bare-metal test build artifacts (sources .S/.ld/manifest +
# the *.golden reference trace stay tracked; .bin/.elf/.o are rebuilt by make)
verif/sys/tests/**/*.elf
verif/sys/tests/**/*.bin
verif/sys/tests/**/*.o

# sphinx docs build output (sources under docs/sphinx/ are tracked)
docs/sphinx/_build/
/_site/

# python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# tooling / agent scratch
.claude/

# editor
*.swp
.DS_Store
